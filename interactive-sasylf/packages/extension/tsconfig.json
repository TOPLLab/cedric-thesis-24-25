{
	"compilerOptions": {
		"module": "nodenext",
		"target": "es2022",
		"moduleResolution": "nodenext",
		"resolveJsonModule": true,
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"strict": true,
		"noImplicitReturns": true,
		"rootDir": ".",
		"baseUrl": ".",
		"jsx": "react-jsx",
		"paths": {
			"@/*": [
				"./src/*"
			]
		}
	}
}
