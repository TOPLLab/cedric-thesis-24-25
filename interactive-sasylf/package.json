{
  "name": "live-sasylf",
  "displayName": "Live SASyLF",
  "version": "0.0.1",
  "packageManager": "pnpm@9.12.3",
  "type": "module",
  "engines": {
    "vscode": "^1.96.4"
  },
  "categories": [
    "Education",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:sasylf"
  ],
  "main": "./packages/extension/dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "live-sasylf.runToCursor",
        "title": "SASyLF: Run To Step Under Cursor"
      },
      {
        "command": "live-sasylf.runNext",
        "title": "SASyLF: Run Next Step"
      },
      {
        "command": "live-sasylf.openContextView",
        "title": "SASyLF: Open Context View"
      },
      {
        "command": "live-sasylf.restartCurrentProcess",
        "title": "SASyLF: Restart Current Process"
      }
    ],
    "languages": [
      {
        "id": "sasylf",
        "extensions": [
          ".slf"
        ],
        "aliases": [
          "SASyLF"
        ],
        "filenamePatterns": [
          "*.slf"
        ]
      }
    ],
    "grammars": [
      {
        "language": "sasylf",
        "scopeName": "source.sasylf",
        "path": "./syntaxes/sasylf.tmLanguage.json"
      }
    ]
  },
  "files": [
    "lib/"
  ],
  "scripts": {
    "build": "turbo run build",
    "vscode:prepublish": "turbo run build",
    "build:production": "pnpm package",
    "watch": "turbo run watch",
    "package": "turbo run build:production",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "eslint": "^9.37.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "turbo": "^2.5.8",
    "typescript-eslint": "^8.46.1"
  }
}
