{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": [
				"^lint"
			],
			"outputLogs": "new-only",
			"outputs": [
				"dist/**"
			]
		},
		"build:production": {
			"dependsOn": [
				"^lint"
			],
			"outputLogs": "new-only",
			"outputs": [
				"dist/**"
			]
		},
		"watch": {
			"dependsOn": [],
			"outputLogs": "new-only",
			"outputs": [
				"dist/**"
			]
		},
		"lint": {
			"dependsOn": [],
			"outputLogs": "full",
			"outputs": []
		}
	}
}
